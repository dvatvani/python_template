# Project tasks (in-situ commands; see https://just.systems/)

set shell := ["bash", "-euc"]

[private]
default:
  just --list

[private]
_sync:
    uv sync

# Build the project (removes dist/ then builds)
build: _sync
    rm -rvf ./dist
    uv build

# Install dev dependencies and pre-commit hooks
install: sync
    uv run pre-commit install

# Lint and format-check with ruff
lint: _sync
    echo "--Checking code format--"
    uv run ruff format --check ./src ./tests
    echo "--Linting all sources--"
    uv run ruff check ./src ./tests

# Bump version, create git tag, and push
github-tag: _sync
    #!/usr/bin/env bash
    set -e
    uv run cz bump
    VERSION="$(uv run cz version --project)"
    TAG="v${VERSION}"
    CHANGELOG="$(uv run cz changelog "${VERSION}" --dry-run 2>&1 || echo "Release ${TAG}")"
    echo "Creating tag ${TAG}..."
    git tag -a "${TAG}" -m "Release ${TAG}" -m "${CHANGELOG}"
    echo "Pushing ${TAG} to origin..."
    git push origin "${TAG}"
    echo "Tag ${TAG} created and pushed successfully."

# Print current project version
print-version: _sync
    uv run cz version --project

# Synchronize dependencies from lockfile
sync:
    uv sync

# Run tests and remove __pycache__ / .pyc
tests: _sync
    uv run pytest -v
    find . | grep -E "(__pycache__|\.pyc|\.pyo$)" | xargs rm -rf

# Type-check with ty
type-check: _sync
    uv run ty check
