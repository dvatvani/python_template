# Project tasks (in-situ commands; see https://just.systems/)

set shell := ["bash", "-euc"]

[private]
_sync:
    uv sync

# Build the project (removes dist/ then builds)
build: _sync
    rm -rvf ./dist
    uv build

# Install dev dependencies and pre-commit hooks
install: sync
    uv run pre-commit install

# Lint and format-check with ruff
lint: _sync
    echo "--Checking code format--"
    uv run ruff format --check ./src ./tests
    echo "--Linting all sources--"
    uv run ruff check ./src ./tests

# Initialize documentation branch (gh-pages)
init-docs: _sync
    #!/usr/bin/env bash
    set -euo pipefail
    current_branch="$(git rev-parse --abbrev-ref HEAD)"
    git checkout --orphan gh-pages
    git reset --hard
    git clean -fdx
    uv venv
    uv pip install pre-commit
    uv run pre-commit install || true
    echo "# Documentation" > README.md
    git add README.md
    PRE_COMMIT_ALLOW_NO_CONFIG=1 git commit -m "feat: Initial commit on docs branch" --no-verify --all
    git push -u origin gh-pages
    git switch "${current_branch}"

# Publish documentation to GitHub Pages (mike deploy)
github-pages: _sync
    #!/usr/bin/env bash
    set -e
    echo "Retrieving current project version..."
    VERSION=$(uv run cz version --project)
    echo "Current version: ${VERSION}"
    echo "Generate full changelog"
    uv run cz changelog
    echo "List documentation versions..."
    uv run mike list
    echo "Deploying ${VERSION} as 'latest' version using mike..."
    uv run mike deploy --branch gh-pages --push "${VERSION}" latest --update-aliases --alias-type=copy
    echo "Ensure default version is set to 'latest'..."
    uv run mike set-default --branch gh-pages --push latest
    echo 'OK'

# Bump version, create git tag, and push
github-tag: _sync
    #!/usr/bin/env bash
    set -e
    uv run cz bump
    VERSION="$(uv run cz version --project)"
    TAG="v${VERSION}"
    CHANGELOG="$(uv run cz changelog "${VERSION}" --dry-run 2>&1 || echo "Release ${TAG}")"
    echo "Creating tag ${TAG}..."
    git tag -a "${TAG}" -m "Release ${TAG}" -m "${CHANGELOG}"
    echo "Pushing ${TAG} to origin..."
    git push origin "${TAG}"
    echo "Tag ${TAG} created and pushed successfully."

# Print current project version
print-version: _sync
    uv run cz version --project

# Synchronize dependencies from lockfile
sync:
    uv sync

# Run tests and remove __pycache__ / .pyc
tests: _sync
    uv run pytest -v
    find . | grep -E "(__pycache__|\.pyc|\.pyo$)" | xargs rm -rf

# Type-check with ty
type-check: _sync
    uv run ty check

# Build Docker image
docker-build: _sync
    docker build -t {{ project_slug_underscore }}:latest -f scripts/docker/Dockerfile .
